# 网关监听地址
DG_LISTEN_ADDR=:8787

# 业务后端地址——为空则从 OSS 远程配置读取
DG_BUSINESS_BASE_URL=

# OSS 远程配置源（多个 URL 以逗号分隔，与客户端 config.yaml 的 remote_config.sources 一致）
DG_OSS_CONFIG_URLS=https://162.14.118.116:17541/down/EJEOtevuiZJH.json,https://162.14.118.116:17541/down/nKpvOaTLD2BF.json,https://162.14.118.116:17541/down/LWswZpykXDpx.json

# OSS 配置 XOR 解密密钥（与客户端编译时的 XOR_KEY dart-define 保持一致）
DG_OSS_XOR_KEY=fastcat920fastcat920

# API 路由前缀
DG_API_PREFIX=/api/v1

# 设备-网关映射持久化文件路径
DG_DATA_FILE=./data/device-gateway.json

# 管理接口访问令牌（Bearer Token）
DG_ADMIN_TOKEN=changemeadmintoken

# JWT 签名密钥（HMAC-SHA256，生产环境请更换）
DG_TOKEN_SECRET=8b1c20223f40e84c07b3f97b28c3c58d674e59d83581ec2b6cc1a962da4b9813

# 会话有效期（小时）
DG_SESSION_TTL_HOURS=720

# 设备数超限策略：kick_oldest 踢出最早设备 / deny_new 拒绝新设备
DG_DEVICE_POLICY=kick_oldest

# 单用户默认最大设备数
DG_DEFAULT_DEVICE_LIMIT=1

# 代理转发到业务后端时的 HTTP 超时（秒）
DG_HTTP_TIMEOUT_SECONDS=20

# 是否信任反向代理传递的 X-Forwarded-For 头
DG_TRUST_FORWARDED_FOR=false
